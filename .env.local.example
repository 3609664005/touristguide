# ==========================================
# 本地开发环境变量模板
# 复制此文件为 .env.local 并填入真实值
# ==========================================

# 管理员密码（必填）
ADMIN_PASSWORD=your-admin-password-here

# Session 加密密钥（必填，至少 32 字符随机字符串）
# 生产环境务必替换为强随机字符串！
SESSION_SECRET=dev-random-secret-at-least-32-characters-long-not-for-production

# GitHub API 配置（生产环境必填，本地开发可选留空）
# Token 需要 repo 权限，创建步骤见 README
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=main